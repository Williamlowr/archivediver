# Backend LLM provider key (used by apps/api)
ANTHROPIC_API_KEY=

# Smithsonian key (used only by apps/mcp-smithsonian)
SMITHSONIAN_API_KEY=

# Local service URLs
API_BASE_URL=http://localhost:8000
# Frontend (Vite loads repo-root .env): use real backend unless UI tests / offline dev
VITE_USE_MOCK=false
VITE_API_BASE_URL=http://localhost:8000
WEB_PORT=5173
API_PORT=8000
MCP_PORT=9000
